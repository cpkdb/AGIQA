{
    "schema_version": "3.0",
    "taxonomy_name": "aigc_quality_degradation_active",
    "description": "AIGC图像质量退化维度体系当前生效版：32个有效维度，按Prompt可控性组织，支持退化prompt设计",
    "controllability_levels": {
        "L1": {
            "description": "高可控：可通过prompt直接描述或暗示"
        },
        "L2": {
            "description": "间接可控：通过场景/风格/复杂描述间接影响"
        },
        "L3": {
            "description": "不可控：仅能通过后处理实现，需标记跳过"
        }
    },
    "perspectives": {
        "technical_quality": {
            "zh": "技术质量",
            "description": "低层视觉信号退化：清晰度、噪声、曝光、颜色保真、纹理细节等",
            "dimensions": {
                "blur": {
                    "zh": "模糊（散焦/运动）",
                    "controllability": "L1",
                    "prompt_strategy": "根据场景类型选择：静态场景用soft focus/dreamy/shallow depth of field；动态场景用motion blur/speed lines/dynamic movement",
                    "original_attributes": [
                        "blur",
                        "defocus_blur",
                        "depth_of_field_mismatch",
                        "motion_blur"
                    ]
                },
                "overexposure": {
                    "zh": "过曝光",
                    "controllability": "L1",
                    "prompt_strategy": "添加bright, washed out, high key lighting, blown highlights, overexposed等描述",
                    "original_attributes": [
                        "overexposure",
                        "blown_highlights"
                    ]
                },
                "underexposure": {
                    "zh": "欠曝光",
                    "controllability": "L1",
                    "prompt_strategy": "添加dark, moody, underlit, low key, silhouette, shadowy等描述",
                    "original_attributes": [
                        "underexposure",
                        "crushed_shadows"
                    ]
                },
                "low_contrast": {
                    "zh": "低对比度",
                    "controllability": "L2",
                    "prompt_strategy": "添加flat, muted, hazy, foggy atmosphere, soft tones等描述",
                    "original_attributes": [
                        "low_contrast",
                        "haze_fog"
                    ]
                },
                "color_cast": {
                    "zh": "偏色/色调偏移",
                    "controllability": "L1",
                    "prompt_strategy": "仅使用负面偏色（sickly green, muddy brown, dead gray），避免可能显得艺术化的暖色调/冷色调",
                    "original_attributes": [
                        "color_distortion",
                        "white_balance_shift",
                        "hue_shift"
                    ]
                },
                "desaturation": {
                    "zh": "欠饱和/褪色",
                    "controllability": "L1",
                    "prompt_strategy": "添加faded, desaturated, pale colors, muted tones, washed out colors等描述",
                    "original_attributes": [
                        "low_contrast",
                        "dull_palette"
                    ]
                },
                "plastic_waxy_texture": {
                    "zh": "塑料/蜡质质感",
                    "controllability": "L2",
                    "prompt_strategy": "添加smooth skin, airbrushed, porcelain skin, flawless complexion等描述",
                    "original_attributes": [
                        "over_smoothing",
                        "waxy_plastic_texture",
                        "loss_of_fine_detail"
                    ]
                }
            }
        },
        "aesthetic_quality": {
            "zh": "美学质量",
            "description": "审美与艺术表达：构图、光影氛围、色彩风格、整体观感等",
            "dimensions": {
                "awkward_positioning": {
                    "zh": "布局死板/尴尬",
                    "controllability": "L1",
                    "prompt_strategy": "添加dead center, clinical style, stiff composition, boring layout, surveillance angle等描述",
                    "original_attributes": [
                        "poor_composition",
                        "weak_focal_point"
                    ]
                },
                "awkward_framing": {
                    "zh": "取景/透视畸变",
                    "controllability": "L1",
                    "prompt_strategy": "添加unflattering angle, fisheye lens, wide angle distortion, bulging, tangent crop等描述",
                    "original_attributes": [
                        "awkward_cropping",
                        "subject_cut_off"
                    ]
                },
                "unbalanced_layout": {
                    "zh": "画面失衡",
                    "controllability": "L1",
                    "prompt_strategy": "添加asymmetrical, off-center weight, unbalanced composition等描述",
                    "original_attributes": [
                        "unbalanced_layout",
                        "misaligned_horizon"
                    ]
                },
                "cluttered_scene": {
                    "zh": "画面杂乱",
                    "controllability": "L1",
                    "prompt_strategy": "添加busy background, many objects, crowded scene, chaotic arrangement等描述",
                    "original_attributes": [
                        "cluttered_scene",
                        "distracting_background"
                    ]
                },
                "lighting_imbalance": {
                    "zh": "光照不均",
                    "controllability": "L2",
                    "prompt_strategy": "描述多光源场景或侧光，添加uneven lighting, side lit, mixed lighting等描述",
                    "original_attributes": [
                        "lighting_imbalance",
                        "uneven_exposure"
                    ]
                },
                "color_clash": {
                    "zh": "配色冲突",
                    "controllability": "L1",
                    "prompt_strategy": "添加clashing colors, complementary contrast, bold color mix, neon on pastel等描述",
                    "original_attributes": [
                        "unharmonious_colors",
                        "conflicting_color_temperature"
                    ]
                },
                "dull_palette": {
                    "zh": "色调沉闷",
                    "controllability": "L1",
                    "prompt_strategy": "添加muted colors, grey tones, dull palette, desaturated, lifeless colors等描述",
                    "original_attributes": [
                        "dull_palette",
                        "blandness"
                    ]
                }
            }
        },
        "semantic_rationality": {
            "zh": "语义/合理性",
            "description": "语义理解与现实合理性：解剖结构、物体属性、空间关系、物理光学、场景上下文等",
            "dimensions": {
                "hand_malformation": {
                    "zh": "手部畸形（含手指/姿态异常）",
                    "controllability": "L2",
                    "prompt_strategy": "添加手部描述触发退化：holding, pointing, gesture等",
                    "original_attributes": [
                        "hand_deformity",
                        "finger_count_error",
                        "fused_fingers",
                        "unnatural_hand_pose"
                    ]
                },
                "expression_mismatch": {
                    "zh": "表情与语境不符",
                    "controllability": "L1",
                    "prompt_strategy": "添加矛盾的表情描述，如sad eyes with smiling mouth, confused expression等",
                    "original_attributes": [
                        "expression_mismatch"
                    ]
                },
                "body_proportion_error": {
                    "zh": "身体比例失调",
                    "controllability": "L1",
                    "prompt_strategy": "添加exaggerated proportions, elongated limbs, stylized body, distorted figure等描述",
                    "original_attributes": [
                        "body_proportion",
                        "limb_abnormality"
                    ]
                },
                "extra_limbs": {
                    "zh": "多余/重复肢体",
                    "controllability": "L2",
                    "prompt_strategy": "intertwined fingers, complex gesture, motion blur arms, double exposure limbs, surreal duplication of parts, fractal limbs",
                    "original_attributes": [
                        "duplicated_body_parts",
                        "limb_abnormality"
                    ]
                },
                "animal_anatomy_error": {
                    "zh": "动物解剖错误",
                    "controllability": "L2",
                    "prompt_strategy": "添加mythical creature, hybrid animal, mutant, chimera等描述",
                    "original_attributes": [
                        "animal_anatomy_error"
                    ]
                },
                "object_structure_error": {
                    "zh": "物体结构错误",
                    "controllability": "L2",
                    "prompt_strategy": "只对单个结构化非生物物体引入明显结构失败，包括形状扭曲、部件连接错误、部件数量错误、关键朝向错误或轮廓/线条错误",
                    "original_attributes": [
                        "object_deformation",
                        "broken_geometry",
                        "melted_objects",
                        "incorrect_object_shape",
                        "incorrect_object_orientation"
                    ]
                },
                "material_mismatch": {
                    "zh": "材质错配",
                    "controllability": "L1",
                    "prompt_strategy": "保持对象类别和形状不变，只将材质观感改成明显不符合其类别的表面外观",
                    "original_attributes": [
                        "material_mismatch",
                        "surface_property_error",
                        "texture_semantic_conflict"
                    ]
                },
                "extra_objects": {
                    "zh": "多余/重复物体",
                    "controllability": "L1",
                    "prompt_strategy": "列举多个同类物体several, multiple, many, various等",
                    "original_attributes": [
                        "extra_parts",
                        "duplicated_objects",
                        "hallucinated_objects"
                    ]
                },
                "count_error": {
                    "zh": "数量错误",
                    "controllability": "L1",
                    "prompt_strategy": "使用模糊数量词some, few, several替代精确数字，或故意写错数量",
                    "original_attributes": [
                        "count_error_excessive_objects"
                    ]
                },
                "illogical_colors": {
                    "zh": "逻辑色彩错误",
                    "controllability": "L1",
                    "prompt_strategy": "使用反常识颜色purple grass, green sky, blue banana等",
                    "original_attributes": [
                        "illogical_colors"
                    ]
                },
                "scale_inconsistency": {
                    "zh": "尺度不一致",
                    "controllability": "L1",
                    "prompt_strategy": "混合描述giant and tiny, miniature with large, forced perspective等",
                    "original_attributes": [
                        "scale_inconsistency"
                    ]
                },
                "floating_objects": {
                    "zh": "悬浮无支撑",
                    "controllability": "L1",
                    "prompt_strategy": "添加floating, levitating, suspended in air, hovering, defying gravity等描述",
                    "original_attributes": [
                        "floating_objects",
                        "gravity_violation"
                    ]
                },
                "penetration_overlap": {
                    "zh": "重叠/融合异常",
                    "controllability": "L2",
                    "prompt_strategy": "描述两个实体之间明显不合理的重叠、融合、咬边或错误连接，而不是严格物理穿透",
                    "original_attributes": [
                        "penetration_overlap",
                        "occlusion_error"
                    ]
                },
                "context_mismatch": {
                    "zh": "上下文不匹配",
                    "controllability": "L1",
                    "prompt_strategy": "混合不合理元素beach + snow, medieval + smartphone, underwater + fire等",
                    "original_attributes": [
                        "contextual_mismatch",
                        "semantic_contradiction",
                        "prompt_conflict"
                    ]
                },
                "time_inconsistency": {
                    "zh": "时间/季节矛盾",
                    "controllability": "L1",
                    "prompt_strategy": "混合时间线索sunrise + stars, summer clothes + snow, day and night等",
                    "original_attributes": [
                        "time_season_inconsistency"
                    ]
                },
                "scene_layout_error": {
                    "zh": "场景布局错误",
                    "controllability": "L2",
                    "prompt_strategy": "描述不合理的空间安排或家具配置",
                    "original_attributes": [
                        "scene_layout_error",
                        "implausible_scene_design",
                        "incorrect_scene_elements"
                    ]
                },
                "text_error": {
                    "zh": "文字错误（拼写/乱码/模糊）",
                    "controllability": "L2",
                    "prompt_strategy": "修改文字内容引入拼写错误，或添加模糊/难以辨认描述",
                    "original_attributes": [
                        "text_legibility",
                        "gibberish_text",
                        "unreadable_name",
                        "incorrect_spelling",
                        "incorrect_address_text"
                    ]
                },
                "logo_symbol_error": {
                    "zh": "图标/符号错误",
                    "controllability": "L2",
                    "prompt_strategy": "要求生成特定品牌logo或复杂图标",
                    "original_attributes": [
                        "iconography_error",
                        "logo_error",
                        "typography_style_mismatch"
                    ]
                }
            }
        }
    },
