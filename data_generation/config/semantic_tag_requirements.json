{
  "schema_version": "1.0",
  "description": "正样本语义标签体系及维度映射配置",
  "tags": {
    "has_person": {
      "zh": "包含人物",
      "description": "图像中包含人物（全身、半身或局部均可）",
      "detection_keywords": [
        "person",
        "people",
        "man",
        "woman",
        "boy",
        "girl",
        "child",
        "human",
        "figure",
        "portrait",
        "face",
        "body"
      ]
    },
    "has_face": {
      "zh": "包含人脸",
      "description": "图像中包含清晰可见的人脸（正脸或侧脸）",
      "detection_keywords": [
        "face",
        "portrait",
        "headshot",
        "close-up of person",
        "facial",
        "expression",
        "eyes",
        "smile"
      ]
    },
    "has_hand": {
      "zh": "包含手部",
      "description": "图像中包含清晰可见的手部（手持物品也算）",
      "detection_keywords": [
        "hand",
        "hands",
        "holding",
        "grabbing",
        "pointing",
        "gesture",
        "fingers",
        "grasping",
        "reaching"
      ]
    },
    "has_full_body": {
      "zh": "包含完整人体",
      "description": "图像中包含完整的人体（从头到脚）",
      "detection_keywords": [
        "full body",
        "standing",
        "walking",
        "running",
        "sitting",
        "full figure",
        "whole body"
      ]
    },
    "has_animal": {
      "zh": "包含动物",
      "description": "图像中包含动物（真实动物或拟人化动物）",
      "detection_keywords": [
        "animal",
        "dog",
        "cat",
        "bird",
        "horse",
        "lion",
        "tiger",
        "bear",
        "fish",
        "rabbit",
        "elephant",
        "wolf",
        "fox",
        "deer",
        "creature",
        "pet"
      ]
    },
    "has_multiple_objects": {
      "zh": "包含多个物体",
      "description": "图像中包含多个独立可分辨的物体",
      "detection_keywords": [
        "and",
        "with",
        "multiple",
        "several",
        "many",
        "various",
        "collection",
        "group of",
        "set of",
        "arrangement"
      ]
    },
    "has_countable_objects": {
      "zh": "包含可计数物体",
      "description": "图像中包含具体数量的可计数物体",
      "detection_keywords": [
        "two",
        "three",
        "four",
        "five",
        "six",
        "seven",
        "eight",
        "nine",
        "ten",
        "pair",
        "couple",
        "dozen",
        "2",
        "3",
        "4",
        "5"
      ]
    },
    "has_indoor_scene": {
      "zh": "室内场景",
      "description": "图像是室内场景（有房间、家具等）",
      "detection_keywords": [
        "room",
        "indoor",
        "interior",
        "house",
        "home",
        "apartment",
        "kitchen",
        "bedroom",
        "living room",
        "bathroom",
        "office",
        "studio",
        "gallery"
      ]
    },
    "has_background": {
      "zh": "有前景背景分离",
      "description": "图像有明确的前景主体和背景分离",
      "detection_keywords": [
        "background",
        "in front of",
        "against",
        "with ... behind",
        "foreground",
        "backdrop"
      ]
    },
    "has_text": {
      "zh": "包含文字",
      "description": "图像中包含文字、标牌、书籍等文字元素",
      "detection_keywords": [
        "text",
        "sign",
        "signage",
        "letter",
        "letters",
        "word",
        "words",
        "writing",
        "book",
        "newspaper",
        "magazine",
        "poster",
        "banner",
        "label",
        "title"
      ]
    },
    "has_quoted_text": {
      "zh": "包含引号内文字",
      "description": "Prompt中包含引号内的具体文字内容，用于text_error维度筛选",
      "detection_method": "regex"
    },
    "has_reflective_surface": {
      "zh": "包含反射面",
      "description": "图像中包含镜面、水面、玻璃等可产生反射的表面",
      "detection_keywords": [
        "mirror",
        "reflection",
        "reflective",
        "water",
        "lake",
        "pond",
        "river",
        "pool",
        "glass",
        "window",
        "shiny",
        "metallic surface",
        "chrome"
      ]
    },
    "has_logo_or_symbol": {
      "zh": "包含logo或符号",
      "description": "图像中包含品牌logo、图标或特定符号",
      "detection_keywords": [
        "logo",
        "brand",
        "symbol",
        "icon",
        "emblem",
        "badge",
        "trademark",
        "sign"
      ]
    },
    "has_structured_object": {
      "zh": "包含结构化物体",
      "description": "图像中包含有明确结构特征的物体（家具、容器、交通工具、建筑等），适合object_shape_error维度",
      "detection_keywords": [
        "chair",
        "bench",
        "table",
        "desk",
        "shelf",
        "ladder",
        "fence",
        "pole",
        "frame",
        "mug",
        "cup",
        "bottle",
        "bicycle",
        "bike",
        "cart",
        "car",
        "vehicle",
        "door",
        "window",
        "stool",
        "sofa",
        "couch",
        "bed",
        "cabinet",
        "bookshelf",
        "lamppost",
        "streetlight",
        "railing",
        "handrail",
        "wheel",
        "tire",
        "ball",
        "globe",
        "building",
        "house",
        "tower",
        "bridge"
      ]
    }
  },
  "dimension_requirements": {
    "_comment": "每个维度需要的标签，null表示无要求（可使用任意正样本）",
    "technical_quality": {
      "blur": null,
      "overexposure": null,
      "underexposure": null,
      "low_contrast": null,
      "color_cast": null,
      "desaturation": null,
      "plastic_waxy_texture": {
        "preferred": [
          "has_person",
          "has_face"
        ],
        "required": null,
        "note": "人物皮肤效果最明显，但也可应用于任何图像"
      }
    },
    "aesthetic_quality": {
      "awkward_positioning": null,
      "awkward_framing": null,
      "unbalanced_layout": null,
      "cluttered_scene": null,
      "lighting_imbalance": null,
      "color_clash": null,
      "dull_palette": null
    },
    "semantic_rationality": {
      "hand_malformation": {
        "required": [
          "has_hand"
        ],
        "preferred": [
          "has_person"
        ],
        "note": "必须有明确的手部描述（has_hand标签），has_person仅作为优先选择"
      },
      "face_asymmetry": {
        "required": [
          "has_face"
        ],
        "note": "必须有清晰可见的人脸"
      },
      "expression_mismatch": {
        "required": [
          "has_face",
          "has_person"
        ],
        "note": "必须有人脸且是人物（不能是动物或艺术装置）才适合表情失配"
      },
      "body_proportion_error": {
        "required": [
          "has_person"
        ],
        "preferred": [
          "has_full_body"
        ],
        "note": "必须有人体，完整人体效果更好"
      },
      "extra_limbs": {
        "required": [
          "has_person"
        ],
        "note": "必须有人体"
      },
      "impossible_pose": {
        "required": [
          "has_person"
        ],
        "preferred": [
          "has_full_body"
        ],
        "note": "必须有人体"
      },
      "animal_anatomy_error": {
        "required": [
          "has_animal"
        ],
        "note": "必须有动物"
      }
    },
    "semantic_object": {
      "object_shape_error": {
        "preferred": [
          "has_structured_object"
        ],
        "required": null,
        "note": "有结构物体（家具、交通工具、建筑等）效果更好"
      },
      "extra_objects": null,
      "count_error": {
        "preferred": [
          "has_countable_objects"
        ],
        "required": null,
        "note": "有可计数物体效果更好"
      },
      "illogical_colors": null
    },
    "semantic_spatial": {
      "scale_inconsistency": {
        "preferred": [
          "has_multiple_objects"
        ],
        "required": null,
        "note": "有多个物体时尺度对比更明显"
      },
      "floating_objects": null,
      "penetration_overlap": {
        "preferred": [
          "has_multiple_objects"
        ],
        "required": null,
        "note": "有多个物体时才能产生穿透重叠"
      },
      "shadow_mismatch": null,
      "reflection_error": {
        "required": [
          "has_reflective_surface"
        ],
        "note": "必须有镜面/水面等反射面"
      },
      "context_mismatch": null,
      "time_inconsistency": null,
      "scene_layout_error": {
        "preferred": [
          "has_indoor_scene"
        ],
        "required": null,
        "note": "室内场景的布局错误更明显"
      }
    },
    "semantic_text": {
      "text_error": {
        "required": [
          "has_text"
        ],
        "note": "必须有文字元素，代码中会额外检测引号"
      },
      "logo_symbol_error": {
        "required": [
          "has_logo_or_symbol"
        ],
        "alternative": [
          "has_text"
        ],
        "note": "必须有logo/符号，或至少有文字"
      }
    }
  },
  "summary": {
    "total_dimensions": 35,
    "dimensions_requiring_tags": {
      "strict_required": [
        "hand_malformation",
        "face_asymmetry",
        "expression_mismatch",
        "body_proportion_error",
        "extra_limbs",
        "impossible_pose",
        "animal_anatomy_error",
        "reflection_error",
        "text_error",
        "logo_symbol_error"
      ],
      "preferred_but_not_required": [
        "plastic_waxy_texture",
        "count_error",
        "object_shape_error",
        "scale_inconsistency",
        "penetration_overlap",
        "scene_layout_error"
      ]
    },
    "required_tags_usage": {
      "has_person": [
        "expression_mismatch",
        "body_proportion_error",
        "extra_limbs",
        "impossible_pose"
      ],
      "has_face": [
        "face_asymmetry",
        "expression_mismatch"
      ],
      "has_hand": [
        "hand_malformation"
      ],
      "has_animal": [
        "animal_anatomy_error"
      ],
      "has_multiple_objects": [],
      "has_reflective_surface": [
        "reflection_error"
      ],
      "has_text": [
        "text_error",
        "logo_symbol_error(alt)"
      ],
      "has_logo_or_symbol": [
        "logo_symbol_error"
      ]
    }
  }
}
